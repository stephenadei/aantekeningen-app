// Unified Prisma Schema (SSOT)
// Combines privelessen-dashboard and aantekeningen-app schemas

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
  output        = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USER & AUTH
// ==========================================

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String? // bcrypt hash (optional for backward compatibility)
  role      UserRole @default(TUTOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  notes   Note[]
  lessons Lesson[] @relation("TutorLessons") // Explicit relation name

  // Aantekeningen-app compatibility
  lessonsAsUser Lesson[] @relation("UserLessons") // Relation for aantekeningen-app specific 'userId' field

  // Aantekeningen-app extensions
  loginAudits      LoginAudit[]
  confirmedFolders UnlinkedFolder[]

  @@map("users")
}

enum UserRole {
  ADMIN
  TUTOR
  STUDENT // Added from aantekeningen-app
}

// ==========================================
// STUDENT & GUARDIAN
// ==========================================

model Student {
  id                 String       @id @default(cuid())
  name               String
  email              String?
  phone              String?
  schoolLevel        SchoolLevel?
  postcode           String?
  distanceKm         Int?
  segment            Segment?
  customerSince      DateTime?
  weekendWhitelisted Boolean      @default(false)
  language           Language?    @default(DUTCH)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Chatwoot integration
  chatwootContactId String? @unique
  chatwootAccountId String?

  // Aantekeningen-app integration
  pinHash      String? // bcrypt hash for PIN login
  datalakePath String? // Path to student folder in MinIO datalake (e.g., "notability/Priveles/VO/Amirah")
  shareToken   String? @unique // Added from aantekeningen-app

  // Relations
  guardians     Guardian[]
  notes         Note[]
  lessons       Lesson[]
  payments      Payment[]
  packages      Package[]
  conversations Conversation[]
  appointments  Appointment[]
  quotes        Quote[]

  // Aantekeningen-app extensions
  loginAudits LoginAudit[]
  tags        StudentTag[]

  @@map("students")
}

model Guardian {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guardians")
}

enum SchoolLevel {
  PO
  BASISSCHOOL // Added from aantekeningen-app (likely duplicate of PO)
  VMBO
  HAVO
  VWO
  MBO
  UNIVERSITY_WO
  UNIVERSITY_HBO // Dashboard uses this
  HBO // Aantekeningen uses this
  WO // Aantekeningen uses this
  ADULT
  OVERIG // Aantekeningen uses this
}

enum Segment {
  NEW
  EXISTING
  RETURNING_BROADCAST
  WEEKEND
  INACTIVE // Added from aantekeningen-app
}

enum Language {
  DUTCH
  ENGLISH
}

// ==========================================
// LESSONS
// ==========================================

model Lesson {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Dashboard Fields
  tutorId String?
  tutor   User?     @relation("TutorLessons", fields: [tutorId], references: [id])
  start   DateTime? // Made optional to support aantekeningen-app if it only writes 'date'
  end     DateTime? // Made optional

  // Aantekeningen-app Fields
  userId   String? // Used by aantekeningen-app instead of tutorId
  user     User?     @relation("UserLessons", fields: [userId], references: [id])
  date     DateTime? // Used by aantekeningen-app
  duration Int? // Used by aantekeningen-app (minutes)

  status   LessonStatus @default(SCHEDULED)
  location String?
  notes    String? // Simple notes string

  // Package relationship
  packageId String?
  package   Package? @relation(fields: [packageId], references: [id])

  // TutorBot integration fields
  program               Program?
  topicPrimary          String?
  topicSecondary        String?
  toolset               String?
  lessonMode            LessonMode?
  isAdult               Boolean     @default(false)
  relationshipToLearner String?

  // Google Calendar integration
  googleCalendarEventId String?
  googleCalendarColorId String?

  // Relations
  noteRecords Note[] // One-to-many

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lessons")
}

enum LessonStatus {
  SCHEDULED
  PLANNED // Aantekeningen-app uses this
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LessonMode {
  ONLINE
  IN_PERSON
  HYBRID
}

// ==========================================
// NOTES
// ==========================================

model Note {
  id String @id @default(cuid())

  // Relations
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  authorId String? // Optional for aantekeningen-app
  author   User?   @relation(fields: [authorId], references: [id])

  userId String? // Aantekeningen-app uses this
  // Note: 'user' relation from aantekeningen-app likely maps to authorId or userId. 
  // We keep authorId as primary but might need userId if strictly required.

  // Note Type & Content
  type    NoteType @default(TEXT)
  title   String?
  body    String? // Dashboard content
  content String? // Aantekeningen-app content

  // Datalake Integration
  datalakePath String?

  // Metadata
  subject    String?
  topicGroup String?
  topic      String?
  level      String?
  schoolYear String?
  keywords   String[]

  // Status & Organization
  status    NoteStatus @default(ACTIVE)
  tags      String[]
  isPrivate Boolean    @default(false)

  // Timestamps
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lessonDate DateTime?

  // Relations
  attachments NoteAttachment[]

  // Aantekeningen-app extensions
  keyConcepts KeyConcept[]

  @@index([studentId, lessonId])
  @@index([studentId, createdAt])
  @@index([lessonId])
  @@map("notes")
}

enum NoteType {
  TEXT
  PDF
  MARKDOWN
  AUDIO
  IMAGE
  LINK
}

enum NoteStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model NoteAttachment {
  id     String @id @default(cuid())
  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  type         String
  filename     String
  datalakePath String
  size         Int?

  createdAt DateTime @default(now())

  @@map("note_attachments")
}

// ==========================================
// PAYMENTS & PACKAGES
// ==========================================

model Payment {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  amount      Int? // Dashboard (cents). Optional for compatibility.
  amountFloat Float? // Aantekeningen-app uses Float. 

  currency    String         @default("EUR")
  status      PaymentStatus  @default(PENDING)
  method      PaymentMethod?
  stripeId    String?        @unique
  description String?
  metadata    Json?

  // Manual payment link
  manualPaymentLink   String?
  manualLinkExpiresAt DateTime?

  // Package relationship
  packageId String?  @unique
  package   Package? @relation("PackagePayment") // One-to-one

  // Quote relationship
  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  // TutorBot integration
  orderId String? @unique
  priceId String?

  // Payment date - set to first lesson date when lesson is linked to package
  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  IDEAL
  CREDIT_CARD
  BANK_TRANSFER
  CASH
}

model Package {
  id        String        @id @default(cuid())
  studentId String
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      PackageType
  status    PackageStatus @default(PENDING_PAYMENT)

  // Dashboard Fields
  totalHours   Int? // Optional
  usedHours    Int  @default(0)
  studentCount Int  @default(1)

  // Aantekeningen-app Fields
  name        String?
  lessonsLeft Int?
  expiresAt   DateTime?

  // Pricing
  schoolLevel     SchoolLevel? // School level selected for this package (overrides student's level)
  price           Int? // Dashboard uses Int (cents)
  priceFloat      Float? // Aantekeningen-app uses Float
  pricePerStudent Int?

  // Payment
  paymentId String?  @unique
  payment   Payment? @relation("PackagePayment", fields: [paymentId], references: [id], onDelete: SetNull)

  // Quote relationship
  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  // Metadata for quote packages
  quoteMonth Int? // Month (1-12) for quote packages
  quoteYear  Int? // Year for quote packages

  // Metadata
  notes    String?
  metadata Json?

  // Relations
  lessons Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("packages")
}

enum PackageType {
  PACKAGE_4H
  URGENT_2H
  QUOTE_PACKAGE
  HOURLY // Aantekeningen
  SUBSCRIPTION // Aantekeningen
  BUNDLE // Aantekeningen
}

enum PackageStatus {
  PENDING_PAYMENT
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

// ==========================================
// QUOTES
// ==========================================

model Quote {
  id        String      @id @default(cuid())
  studentId String
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    QuoteStatus @default(DRAFT)

  // Contact information
  contactPerson String? // e.g., "Betty Arthur"
  contactEmail  String?
  contactPhone  String?

  // Dates
  startDate DateTime
  endDate   DateTime

  // Pricing
  totalAmount Int // Total amount in cents
  currency    String @default("EUR")

  // Metadata
  quoteNumber String? @unique // e.g., "Q-2025-001"
  pdfPath     String? // Path to uploaded offerte PDF
  notes       String?
  metadata    Json?

  // Relations
  templates QuotePackageTemplate[]
  packages  Package[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quotes")
}

model QuotePackageTemplate {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  // Month/Year for this template
  month Int // 1-12
  year  Int

  // Package details
  packageCount    Int // Number of packages for this month
  pricePerPackage Int // Price per package in cents (can be custom/reduced)

  // Lesson schedule metadata
  lessonSchedule Json? // e.g., { "days": ["tuesday", "thursday"], "time": "19:00-21:00" }

  // Metadata
  notes    String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quoteId, month, year])
  @@map("quote_package_templates")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  ACTIVE
  COMPLETED
  CANCELLED
}

// ==========================================
// APPOINTMENTS & CONVERSATIONS
// ==========================================

model Appointment {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Dashboard
  startsAt DateTime?
  endsAt   DateTime?
  source   AppointmentSource @default(MANUAL)

  // Aantekeningen (mapped)
  title     String?
  startTime DateTime? // Might map to startsAt in logic
  endTime   DateTime? // Might map to endsAt in logic

  status    AppointmentStatus @default(PENDING)
  location  String?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AppointmentSource {
  MANUAL
  GOOGLE_CALENDAR
  MICROSOFT_CALENDAR
  BOT
}

model Conversation {
  id String @id @default(cuid())

  // Dashboard
  externalId String? @unique // Made optional for aantekeningen compatibility
  source     String? // "chatwoot", "whatsapp" etc.

  // Aantekeningen
  channel   String? // Duplicate of source?
  content   String?
  sender    String?
  timestamp DateTime?

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  // Chatwoot integration
  chatwootAccountId String?
  chatwootInboxId   String?
  chatwootStatus    String?

  // TutorBot attributes
  program               Program?
  topicPrimary          String?
  topicSecondary        String?
  toolset               String?
  lessonMode            LessonMode?
  isAdult               Boolean          @default(false)
  relationshipToLearner String?
  languagePrompted      Boolean          @default(false)
  intakeCompleted       Boolean          @default(false)
  planningProfile       PlanningProfile?
  orderId               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  messageLogs MessageLog[]
  labels      ConversationLabel[]

  @@map("conversations")
}

model ConversationLabel {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label          String
  createdAt      DateTime     @default(now())

  @@unique([conversationId, label])
  @@map("conversation_labels")
}

model MessageLog {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  channel        String
  payload        Json
  error          String?
  ts             DateTime         @default(now())

  @@map("message_logs")
}

enum MessageDirection {
  IN
  OUT
}

model WebhookLog {
  id      String   @id @default(cuid())
  source  String
  event   String
  payload Json
  ok      Boolean
  ts      DateTime @default(now())

  @@map("webhook_logs")
}

enum Program {
  NONE
  MBO_REKENEN_2F
  MBO_REKENEN_3F
  IB_MATH_SL
  IB_MATH_HL
  CAMBRIDGE
}

enum PlanningProfile {
  NEW
  EXISTING
  RETURNING_BROADCAST
  WEEKEND
}

// ==========================================
// AANTEKENINGEN-APP SPECIFIC MODELS
// ==========================================

model LoginAudit {
  id            String   @id @default(cuid())
  studentId     String?
  student       Student? @relation(fields: [studentId], references: [id])
  teacherId     String?
  teacher       User?    @relation(fields: [teacherId], references: [id])
  who           String?
  action        String
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@map("login_audits")
}

model KeyConcept {
  id          String   @id @default(cuid())
  noteId      String?
  note        Note?    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  driveFileId String? // Path/ID for lookup
  concept     String
  definition  String
  examples    String[]
  importance  String?
  orderIndex  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("key_concepts")
}

model StudentTag {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tag       String
  color     String?
  createdAt DateTime @default(now())

  @@map("student_tags")
}

model UnlinkedFolder {
  id            String    @id @default(cuid())
  driveFolderId String
  folderName    String
  studentName   String?
  subject       String?
  status        String    @default("pending")
  confirmedAt   DateTime?
  confirmedById String?
  confirmedBy   User?     @relation(fields: [confirmedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("unlinked_folders")
}

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?
  icon        String?
  sortOrder   Int?
  topics      Topic[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("subjects")
}

model Topic {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("topics")
}
