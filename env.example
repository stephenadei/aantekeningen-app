# =============================================================================
# AANTEKENINGEN APP - SELF-HOSTED PRODUCTION
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# This file is for self-hosted deployment (Docker/PM2)

# =============================================================================
# NEXTAUTH CONFIGURATION (REQUIRED)
# =============================================================================
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# NEXTAUTH_URL should match your deployment URL

NEXTAUTH_SECRET=K3GytrQtCLZb4Rt/5pImVfqeuxxofWOXlWOaZg7RJrk=
NEXTAUTH_URL=http://localhost:3000  # Change to https://stephensprive.app in production

# =============================================================================
# DATABASE CONFIGURATION (REQUIRED - For User Authentication)
# =============================================================================
# Uses the same PostgreSQL database as privelessen-dashboard
# Make sure DATABASE_URL points to the same database

DATABASE_URL=postgresql://username:password@localhost:5432/privelessen

# =============================================================================
# SECURITY CONFIGURATION (REQUIRED)
# =============================================================================

ALLOWED_TEACHER_DOMAIN=stephensprivelessen.nl
TEACHER_EMAIL=lessons@stephensprivelessen.nl

# =============================================================================
# MINIO DATALAKE CONFIGURATION (REQUIRED)
# =============================================================================
# MinIO endpoint - use localhost for local MinIO or domain for public MinIO

MINIO_ENDPOINT=http://localhost:9000
# Or if MinIO is in Docker: MINIO_ENDPOINT=platform-minio
# Public endpoint for presigned URLs (required if MINIO_ENDPOINT is a Docker container name)
MINIO_PUBLIC_ENDPOINT=https://platform-minio.stephensprivelessen.nl

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_SECURE=false

# Bucket Names (Medallion Architecture)
DATALAKE_BUCKET_EDUCATION_BRONZE="bronze-education"
DATALAKE_BUCKET_EDUCATION_SILVER="silver-education"

# =============================================================================
# AI CONFIGURATION (OPTIONAL)
# =============================================================================
# Get this from OpenAI Dashboard → API Keys

OPENAI_API_KEY=sk-proj-your-openai-api-key

# =============================================================================
# CACHE CONFIGURATION (OPTIONAL)
# =============================================================================
# How long to cache data in hours (default: 12)

CACHE_DURATION_HOURS=12

# =============================================================================
# CRON SECRET (REQUIRED FOR BACKGROUND SYNC)
# =============================================================================
# Generate with: openssl rand -base64 32
# Used to secure the /api/cron/sync-folders endpoint

CRON_SECRET=your-cron-secret

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================

NODE_ENV=production
PORT=3001

