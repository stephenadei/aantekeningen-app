# Suppress deprecation warnings
audit-level=moderate
fund=false

# Shared @stephenadei/* packages are private on GitHub Packages. Standalone CI
# (no monorepo workspace) installs them from there, authenticating via
# NODE_AUTH_TOKEN (the GHP_READ_TOKEN secret). Local monorepo installs resolve
# these via the workspace, so this registry line is only exercised in CI.
@stephenadei:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
